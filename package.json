{
  "name": "web-publish",
  "version": "1.0.0",
  "description": "HTML Publishing Boilerplate with Bootstrap (Local)",
  "scripts": {
    "setup": "node scripts/setup.js",
    "build": "node scripts/build.js",
    "dev": "browser-sync start --server src --files 'src/**/*.html, src/assets/css/*.css, src/assets/js/*.js' --no-notify",
    "start": "npm run dev"
  },
  "devDependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "browser-sync": "^3.0.3",
    "pretendard": "^1.3.9"
  }
}